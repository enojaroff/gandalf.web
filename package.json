    "gulp-clean-css": "^4.3.0",
    "gulp-htmlmin": "^5.0.1",
    "gulp-if": "^3.0.0",
    "gulp-l10n": "Nebo15/gulp-l10n",
    "gulp-ng-annotate": "^2.1.0",
    "gulp-ng-constant": "^1.2.0",
    "gulp-nodemon": "^2.5.0",
    "gulp-notify": "^4.0.0",
    "gulp-plumber": "^1.2.1",
    "gulp-prefix": "^0.0.14",
