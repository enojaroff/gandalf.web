{
  "name": "gandalf.web",
  "version": "1.0.1",
  "repository": "https://github.com/Nebo15/gandalf.web.git",
  "scripts": {
    "build": "gulp build --production",
    "postinstall": "node scripts/patch-clone-stats.js",
    "start": "node server",
    "test": "gulp test",
    "test:travis": "gulp test:travis",
